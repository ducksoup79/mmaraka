# Copy to .env and fill in values. Do not commit .env.

# Server
PORT=3001
NODE_ENV=production
# Public base URL for payment return/cancel (e.g. https://api.yourdomain.com). Used when creating PayPal orders.
BASE_URL=http://localhost:3001

# Database (PostgreSQL)
# On macOS (Postgres.app / Homebrew) use your Mac username for DB_USER if "postgres" role doesn't exist.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=marketplace

# Admin account (created by npm run setup)
ADMIN_PASSWORD=admin123

# JWT (use long random strings in production)
JWT_SECRET=your_jwt_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_secret_or_same_as_jwt
