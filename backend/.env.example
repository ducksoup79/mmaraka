# Copy to .env and fill in values. Do not commit .env.

# Server
PORT=3001
NODE_ENV=production
# Public base URL for payment return/cancel (e.g. https://api.yourdomain.com). Used when creating PayPal orders.
BASE_URL=http://localhost:3001
# Base URL for password reset link (e.g. https://yourapp.com or your web frontend). User opens link to set new password.
PASSWORD_RESET_BASE_URL=

# Email (for password reset and verification). Run: npm run setup-email
# If not set, reset/verify tokens are created but no email is sent.
# MAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Database (PostgreSQL)
# On macOS (Postgres.app / Homebrew) use your Mac username for DB_USER if "postgres" role doesn't exist.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=marketplace

# Admin account (created by npm run setup)
ADMIN_PASSWORD=admin123

# JWT (use long random strings in production)
JWT_SECRET=your_jwt_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_secret_or_same_as_jwt
