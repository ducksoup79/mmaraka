# Copy to .env and fill in values. Do not commit .env.

# Server
PORT=3001
NODE_ENV=production
# Public base URL for payment return/cancel. Used when creating PayPal orders.
# - Production: https://api.mmaraka.com (so PayPal redirects here after payment, not localhost)
# - Local: http://localhost:3001
# If unset, the server may use return_base_url sent by the mobile app when creating an order.
BASE_URL=http://localhost:3001
# Base URL for password reset link (e.g. https://yourapp.com or your web frontend). User opens link to set new password.
PASSWORD_RESET_BASE_URL=

# Email (for password reset and verification). Mailgun only.
# Get API key and domain from https://app.mailgun.com/ (sandbox domain is fine for testing).
# MAIL_FROM must be a valid sender for your domain (e.g. postmaster@your-domain.mailgun.org).
# MAILGUN_EU=true if your domain is in the EU region.
# MAILGUN_API_KEY=key-xxxxxxxxxxxx
# MAILGUN_DOMAIN=sandboxxxxx.mailgun.org
# MAIL_FROM=Mmaraka <postmaster@sandboxxxxx.mailgun.org>
# MAILGUN_EU=false

# Database (PostgreSQL)
# On macOS (Postgres.app / Homebrew) use your Mac username for DB_USER if "postgres" role doesn't exist.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=marketplace

# Admin account (created by npm run setup)
ADMIN_PASSWORD=admin123

# JWT (use long random strings in production)
JWT_SECRET=your_jwt_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_secret_or_same_as_jwt
